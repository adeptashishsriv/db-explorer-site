rules_version = '2';

// Firestore Security Rules for DB Explorer Blog
//
// HOW TO DEPLOY:
// 1. Install the Firebase CLI: npm install -g firebase-tools
// 2. Log in: firebase login
// 3. Deploy rules only: firebase deploy --only firestore:rules
//
// GITHUB PAGES AUTHORIZED DOMAIN SETUP:
// Before OAuth sign-in will work on GitHub Pages, add your GitHub Pages
// domain to Firebase Authentication authorized domains:
//   Firebase Console -> Authentication -> Settings -> Authorized domains
//   Click "Add domain" and enter your GitHub Pages domain
//   e.g., adeptashish.github.io or your custom CNAME domain

service cloud.firestore {
  match /databases/{database}/documents {
    match /posts/{postId} {
      // Anyone (including unauthenticated visitors) can read published posts
      allow read: if true;

      // Any authenticated user can create a new post
      allow create: if request.auth != null;

      // Only the designated admin OR the post's own author can update
      allow update: if request.auth != null
        && (
          (request.auth.token.email == 'adeptashish@gmail.com' && request.auth.token.email_verified == true)
          || request.auth.uid == resource.data.authorUid
        );

      // Only the designated admin can delete posts
      allow delete: if request.auth != null
        && request.auth.token.email == 'adeptashish@gmail.com'
        && request.auth.token.email_verified == true;
    }
  }
}
